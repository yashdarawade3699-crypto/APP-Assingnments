class Employee:
    def __init__(self, name, salary):
        self.name = name
        self.salary = salary

    @staticmethod
    def is_high_tax(salary):
        return salary > 100000

   
    def check_tax_status(self):
      
        status = Employee.is_high_tax(self.salary)
        print(f"{self.name} High Tax?: {status}")


emp1 = Employee("Alice", 120000)
emp2 = Employee("Bob", 75000)


emp1.check_tax_status()
emp2.check_tax_status()
